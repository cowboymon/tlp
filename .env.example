# Notion Internal Integration token (starts with "secret_")
# Create at https://www.notion.so/my-integrations and share your database with it
NOTION_TOKEN=secret_...

# Sprout Social API token
# Generate at https://app.sproutsocial.com/settings/api
SPROUT_API_TOKEN=...

# Sprout Social customer ID (numeric)
# Find by calling GET https://api.sproutsocial.com/v1/metadata/client
SPROUT_CUSTOMER_ID=...

# Sprout Social group ID (numeric)
# Find under Settings → Groups in the Sprout dashboard
SPROUT_GROUP_ID=...

# Shared secret used to validate incoming Notion webhook requests
# Set this to any strong random string (e.g. openssl rand -hex 32)
# Configure the same value in your Notion automation's webhook header: x-webhook-secret
WEBHOOK_SECRET=...
