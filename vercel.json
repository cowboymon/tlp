{
  "functions": {
    "api/webhook.js": {
      "maxDuration": 30
    },
    "api/trello-webhook.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/trello-webhook",
      "dest": "/api/trello-webhook.js",
      "methods": ["POST", "HEAD"]
    }
  ]
}
